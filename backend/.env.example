# .env.example – 実際の値を .env にコピーして設定してください

DATABASE_URL=postgresql://neondb_owner:xxx@ep-xxx.ap-southeast-1.aws.neon.tech/travelapp?sslmode=require
PERSONAL_API_KEY=your-secret-personal-api-key

# Amadeus API（https://developers.amadeus.com で取得）
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_BASE_URL=https://test.api.amadeus.com

# Kiwi API フォールバック（https://tequila.kiwi.com で取得）
KIWI_API_KEY=

# Trip.com Affiliate（Phase 2）
TRIPCOM_AFFILIATE_ID=
TRIPCOM_API_KEY=

# Google Gemini AI（https://aistudio.google.com で取得）
GEMINI_API_KEY=

# Web Push - VAPID キー（python -c "from pywebpush import generate_vapid_keys; print(generate_vapid_keys())" で生成）
WEBPUSH_VAPID_PRIVATE_KEY=
WEBPUSH_VAPID_PUBLIC_KEY=
WEBPUSH_VAPID_CLAIMS_SUB=mailto:your@email.com

# フロントエンド URL（CORS 許可先）
FRONTEND_URL=http://localhost:3000
